# Personal git config — managed by dotfiles repo
# Override locally with ~/.gitconfig.local (auto-included at the bottom).

[user]
    # Codespaces will set name/email from your GitHub account; uncomment to override:
    # name  = Your Name
    # email = you@example.com

[init]
    defaultBranch = main

[core]
    pager     = delta
    autocrlf  = input
    excludesfile = ~/.gitignore_global
    # NOTE: core.editor intentionally NOT set here. On Linux/macOS the
    # platform-specific ~/.gitconfig.linux override sets it to `vim`.
    # On Windows we leave it unset so git uses the user's platform default.

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate         = true
    side-by-side     = true
    line-numbers     = true
    syntax-theme     = Monokai Extended
    file-decoration-style = blue ul
    hunk-header-decoration-style = blue box

[merge]
    conflictstyle = zdiff3

[diff]
    algorithm     = histogram
    colorMoved    = default
    renames       = copies

[pull]
    rebase = true

[rebase]
    autoSquash = true
    autoStash  = true

[commit]
    verbose = true

[fetch]
    prune     = true
    pruneTags = true

[push]
    autoSetupRemote = true
    followTags   = true

[rerere]
    enabled = true

[log]
    date = iso

[safe]
    # Refuse to auto-trust bare repos discovered in the cwd; require the
    # caller to be inside an explicit GIT_DIR. Defence against malicious
    # repos planted in shared/extracted folders.
    bareRepository = explicit

[help]
    autocorrect = prompt

[alias]
    st     = status -sb
    co     = checkout
    amend  = commit --amend --no-edit
    last   = log -1 HEAD --stat
    lg     = log --graph --pretty=format:'%C(auto)%h%d %s %C(dim)(%cr) %C(blue)<%an>' --abbrev-commit
    lol    = log --graph --decorate --oneline --all
    unstage = reset HEAD --
    pushf  = push --force-with-lease
    fixup  = "!f() { git commit --fixup=$1; }; f"
    wip    = commit -am 'WIP'

    # difftastic — structural / AST-aware diffs (cargo install --locked difftastic)
    dft    = -c diff.external=difft diff
    dfts   = -c diff.external=difft show
    dftl   = -c diff.external=difft log -p

# Layered overrides (last wins; missing files are silently skipped):
#   1. ~/.gitconfig.windows  — per-OS overrides (symlinked by install.ps1 only)
#   2. ~/.gitconfig.linux    — per-OS overrides (symlinked by install.sh only)
#   3. ~/.gitconfig.local    — per-machine identity, credentials, etc.
[include]
    path = ~/.gitconfig.windows
    path = ~/.gitconfig.linux
    path = ~/.gitconfig.local
